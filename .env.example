# Portfolio Environment Configuration Template
# Copy this to .env and fill in your actual values

# =========================
# 🤖 AI INTEGRATIONS (Required)
# =========================

# LLM Provider (choose one: claude, openai, local)
LLM_PROVIDER=claude

# Claude (Anthropic) - Recommended
CLAUDE_API_KEY=replace-with-claude-api-key




#

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8000



# =========================
# 🔐 DEVELOPMENT TOKENS (Optional)
# =========================
# GitHub (for development)
GH_USER=your-github-username
GH_TOKEN=replace-with-github-token

# Docker Hub (for development)
DOCKER_USER=your-docker-username
DOCKER_CRED=your-docker-token

# Hugging Face (for model downloads)
HF_TOKEN=hf-your-hugging-face-token

# =========================
# ☁️ CLOUDFLARE (Optional)
# =========================
CLOUDFLARED_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# =========================
# 🔒 SECURITY
# =========================
SECRET_KEY=generate-a-secure-secret-key-here
JWT_SECRET=generate-a-secure-jwt-secret-here
JWT_ALGORITHM=HS256
